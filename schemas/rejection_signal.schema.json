{
  "$id": "rejection_signal.schema.json",
  "type": "object",
  "required": ["id", "created_at", "updated_at", "source", "confidence", "status", "validation_record_id", "rejection_type", "lesson"],
  "properties": {
    "id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string" },
    "validation_record_id": { "type": "string" },
    "rejection_type": { "type": "string" },
    "lesson": { "type": "string" },
    "stated_reason": { "type": "string" },
    "implicit_reason": { "type": "string" },
    "segment": { "type": "string" },
    "objection": { "type": "string" },
    "follow_up_date": { "type": "string", "format": "date" }
  }
}
