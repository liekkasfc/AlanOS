{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rejection_signal.schema.json",
  "type": "object",
  "required": ["id", "created_at", "updated_at", "source", "confidence", "status", "validation_record_id", "rejection_type", "lesson"],
  "properties": {
    "id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["active", "validated", "archived"] },
    "validation_record_id": { "type": "string" },
    "rejection_type": { "type": "string", "enum": ["silence", "not_urgent", "no_budget", "wrong_buyer", "already_solved", "price_objection", "timing_objection", "scope_mismatch"] },
    "lesson": { "type": "string" },
    "stated_reason": { "type": "string" },
    "implicit_reason": { "type": "string" },
    "segment": { "type": "string" },
    "objection": { "type": "string" },
    "follow_up_date": { "type": "string", "format": "date" }
  }
}
