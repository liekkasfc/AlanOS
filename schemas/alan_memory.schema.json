{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "alan_memory.schema.json",
  "type": "object",
  "required": ["id", "created_at", "updated_at", "source", "confidence", "status", "period", "validated_patterns", "rejected_patterns", "lessons"],
  "properties": {
    "id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["active", "archived"] },
    "period": { "type": "string" },
    "validated_patterns": { "type": "array", "items": { "type": "string" } },
    "rejected_patterns": { "type": "array", "items": { "type": "string" } },
    "lessons": { "type": "array", "items": { "type": "string" } },
    "strong_segments": { "type": "array", "items": { "type": "string" } },
    "weak_segments": { "type": "array", "items": { "type": "string" } },
    "money_dna_updates": { "type": "array", "items": { "type": "string" } },
    "weekly_revenue_signals": { "type": "array", "items": { "type": "string" } },
    "next_biases": { "type": "array", "items": { "type": "string" } }
  }
}
