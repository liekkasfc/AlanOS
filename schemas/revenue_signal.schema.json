{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "revenue_signal.schema.json",
  "type": "object",
  "required": ["id", "created_at", "updated_at", "source", "confidence", "status", "validation_record_id", "signal_type", "strength", "evidence"],
  "properties": {
    "id": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": { "type": "string", "enum": ["active", "validated", "archived"] },
    "validation_record_id": { "type": "string" },
    "signal_type": { "type": "string", "enum": ["serious_reply", "booked_call", "budget_confirmed", "paid_pilot", "deposit", "preorder", "referral", "paid_request"] },
    "strength": { "type": "string", "enum": ["weak", "medium", "strong"] },
    "evidence": { "type": "string" },
    "amount": { "type": "number" },
    "currency": { "type": "string" },
    "buyer": { "type": "string" },
    "next_step": { "type": "string" },
    "expected_close_date": { "type": "string", "format": "date" }
  }
}
